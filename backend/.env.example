# Email Configuration (for Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Chat Webhook (for Google Chat notifications)
# This can be set per-patient or globally
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/xxx/messages?key=xxx&token=xxx

# Scheduler Configuration
# Time to send daily reminders (format: HH:MM in 24-hour format)
# Default is 08:00 (8 AM)
REMINDER_SCHEDULE_TIME=08:00

# Application Timezone
TZ=UTC
